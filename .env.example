# =============================================================================
# RepoPulse Environment Configuration
# =============================================================================
# Hey there! Welcome to the RepoPulse project setup.
# This file contains all the configuration you need to get started.
#
# FIRST TIME SETUP:
# 1. Copy this file: cp .env.example .env (or copy .env.example .env on Windows)
# 2. The default values work great for local development - no changes needed!
# 3. Run ./build.sh (or build.bat on Windows) and you're good to go!
#
# NOTE: Don't commit your .env file to Git - it's already in .gitignore
# =============================================================================

# ── InfluxDB Settings ────────────────────────────────────────────────────────
# This is where all your metrics data gets stored (like LOC, churn, WIP, etc.)

# Username and password for InfluxDB admin
# These are fine for class projects and local testing
INFLUX_INIT_USERNAME=admin
INFLUX_INIT_PASSWORD=adminpass123

# This token lets the API talk to InfluxDB
# The default works perfectly for development
INFLUX_INIT_TOKEN=devtoken12345

# Organization and bucket names (think of these like database names)
INFLUX_ORG=RepoPulseOrg
INFLUX_BUCKET=repopulse_metrics

# How long to keep data (90 days is plenty for a semester project)
INFLUX_RETENTION_DAYS=90

# Where InfluxDB lives (don't change this unless you know what you're doing)
INFLUX_URL=http://influxdb:8086

# ── Grafana Settings ─────────────────────────────────────────────────────────
# Grafana is the cool dashboard where you see all your pretty graphs

# Login credentials for Grafana
# Default is admin/admin - you'll be prompted to change it on first login
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin

# ── API Settings ─────────────────────────────────────────────────────────────
# Settings for the FastAPI backend

# App name (you can change this if you want!)
APP_NAME=RepoPulse

# Debug mode - keep it false unless you're troubleshooting
DEBUG=false

# Where the API listens (these defaults work great)
HOST=0.0.0.0
PORT=8080

# Python path (needed for imports to work correctly)
PYTHONPATH=/app

# ── Worker Settings ──────────────────────────────────────────────────────────
# How many analysis jobs can run at the same time

# 4 workers is a good balance for most laptops
# If you have a beefy machine, you can bump this up to 8
WORKER_POOL_SIZE=4